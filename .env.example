# ═══════════════════════════════════════
# 2H Studio Dashboard v2 — Environment
# ═══════════════════════════════════════

# Database (PostgreSQL — giữ nguyên từ v1)
DATABASE_URL=postgresql://user:pass@your-vps-ip:5432/studio

# Pancake API (Master token — dùng cho sync)
PANCAKE_MASTER_TOKEN=your-pancake-master-token

# Server
API_PORT=3001

# JWT (đăng nhập dashboard)
JWT_SECRET=your-secret-key-change-this

# Encryption (mã hóa page access tokens trong DB)
ENCRYPTION_KEY=your-32-character-encryption-key

# Frontend API URL (dùng bởi Vite)
VITE_API_URL=https://pancake.2hstudio.vn/api
